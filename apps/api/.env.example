NODE_ENV="development"
PORT="4000"
DATABASE_URL="postgresql://mtm:mtm@localhost:5432/mtm?schema=public"
JWT_ACCESS_SECRET="mtm-access-dev-secret"
JWT_REFRESH_SECRET="mtm-refresh-dev-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
ALLOW_PLAIN_PIN_LOGIN="true"
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"
