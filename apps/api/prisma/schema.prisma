generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  MANAGER
  STAFF
}

enum ServiceMode {
  TAKEAWAY
  DINE_IN
}

enum PaymentMethod {
  CASH
  CARD
  TR
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum StockUnit {
  KG
  G
  L
  ML
  UNIT
}

model User {
  id        String   @id @default(cuid())
  name      String
  pinHash   String
  role      UserRole
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TruckSettings {
  id          String   @id @default(cuid())
  name        String
  slogan      String?
  tvaEmporter Decimal  @db.Decimal(5, 2)
  tvaPlace    Decimal  @db.Decimal(5, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String
  color     String
  order     Int
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([name])
}

model Product {
  id            String       @id @default(cuid())
  categoryId    String
  category      Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name          String
  price         Decimal      @db.Decimal(10, 2)
  vatRate       Decimal      @db.Decimal(5, 2)
  isAvailable   Boolean      @default(true)
  imageUrl      String?
  loyaltyPoints Int?
  variants      Variant[]
  recipeItems   RecipeItem[]
  orderItems    OrderItem[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([categoryId])
  @@index([isAvailable])
}

model Variant {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  priceExtra Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
}

model Ingredient {
  id           String       @id @default(cuid())
  name         String
  unit         StockUnit
  currentStock Decimal      @db.Decimal(12, 3)
  minStock     Decimal      @db.Decimal(12, 3)
  costPrice    Decimal      @db.Decimal(10, 3)
  category     String
  recipeItems  RecipeItem[]
  purchases    Purchase[]
  wastes       Waste[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([name])
}

model RecipeItem {
  id           String     @id @default(cuid())
  productId    String
  ingredientId String
  quantity     Decimal    @db.Decimal(12, 3)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([productId, ingredientId])
  @@index([ingredientId])
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  email         String?
  loyaltyPoints Int      @default(0)
  lastVisitAt   DateTime?
  orders        Order[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([name])
  @@index([phone])
  @@index([email])
}

model DailySession {
  id            String        @id @default(cuid())
  startTime     DateTime
  endTime       DateTime?
  initialCash   Decimal       @db.Decimal(12, 2)
  finalCash     Decimal?      @db.Decimal(12, 2)
  totalSales    Decimal       @db.Decimal(12, 2)
  totalExpenses Decimal       @db.Decimal(12, 2)
  ordersCount   Int           @default(0)
  status        SessionStatus
  orders        Order[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([startTime])
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   String
  idempotencyKey String?      @unique
  orderedAt     DateTime      @default(now())
  total         Decimal       @db.Decimal(12, 2)
  status        OrderStatus
  paymentMethod PaymentMethod?
  serviceMode   ServiceMode
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  sessionId     String?
  session       DailySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([orderNumber])
  @@index([status])
  @@index([orderedAt])
  @@index([customerId])
  @@index([sessionId])
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String
  variantName   String?
  quantity      Int
  unitPrice     Decimal  @db.Decimal(12, 2)
  totalPrice    Decimal  @db.Decimal(12, 2)
  isRedeemed    Boolean  @default(false)
  redeemedPoints Int? 
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}

model Purchase {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  supplierName String?
  purchasedAt  DateTime   @default(now())
  quantity     Decimal    @db.Decimal(12, 3)
  totalPrice   Decimal    @db.Decimal(12, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([ingredientId])
  @@index([purchasedAt])
}

model Waste {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  quantity     Decimal    @db.Decimal(12, 3)
  reason       String
  wastedAt     DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([ingredientId])
  @@index([wastedAt])
}

model Expense {
  id            String   @id @default(cuid())
  label         String
  merchant      String
  amountTTC     Decimal  @db.Decimal(12, 2)
  vatAmount     Decimal  @db.Decimal(12, 2)
  category      String
  paymentMethod String
  hasReceipt    Boolean  @default(false)
  spentAt       DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([spentAt])
  @@index([category])
}
